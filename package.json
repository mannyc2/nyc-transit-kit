{
  "name": "nyc-transit-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@effect/platform-bun": "4.0.0-beta.83",
      "effect": "4.0.0-beta.83",
      "gtfs-realtime-bindings": "2.0.0"
    },
    "catalogs": {
      "tooling": {
        "@biomejs/biome": "2.5.0",
        "@types/bun": "1.3.14",
        "typescript": "6.0.3"
      }
    }
  },
  "scripts": {
    "prepare": "./scripts/prepare-effect.sh && effect-language-service patch",
    "check": "bun run check:types && bun run check:effect && bun run check:style && bun test && bun run check:package",
    "check:types": "tsc -b --pretty false --force",
    "check:effect": "effect-language-service diagnostics --project tsconfig.json --format text --strict",
    "check:style": "biome check .",
    "check:style:write": "biome check --write .",
    "check:package": "bun run tests/package-archives/check-package-archives.ts",
    "check:npm-stage": "bun run tests/package-archives/check-npm-release-stage.ts",
    "check:release-config": "bun run scripts/check-release-config.ts",
    "check:release-local": "bun run release:version:check && bun run check && bun run build:cli && bun run release:prepare:npm && bun run check:npm-stage && bun run check:release-config && bun run release:plan",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "cli": "bun run packages/cli/src/main.ts",
    "build": "bun run --filter '*' build",
    "build:cli": "bun run packages/cli/scripts/build-binary.ts",
    "release:version": "bun run scripts/sync-release-version.ts",
    "release:version:check": "bun run scripts/sync-release-version.ts --check",
    "release:prepare:npm": "bun run scripts/prepare-npm-release.ts",
    "release:plan": "bun run scripts/run-ts-release.ts plan --config release.config.json --format text",
    "release:plan:json": "bun run scripts/run-ts-release.ts plan --config release.config.json --format json --out .release/evidence/plan.json",
    "release:validate": "bun run scripts/run-ts-release.ts validate --config release.config.json",
    "release:run": "bun run scripts/run-ts-release.ts run --config release.config.json",
    "release:trust-publishing": "bun run scripts/switch-release-config-to-trusted-publishing.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:tooling",
    "@effect/language-service": "0.86.2",
    "@mannyc1/ts-release": "0.0.3",
    "@types/bun": "catalog:tooling",
    "effect": "catalog:",
    "typescript": "catalog:tooling"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@effect/language-service"
  ],
  "packageManager": "bun@1.3.14"
}
